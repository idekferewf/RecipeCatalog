@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model RecipeCatalog.Controllers.RecipesController.RecipeEditViewModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    if (Model.Recipe.Id == 0)
    {
        ViewData["Title"] = "Добавить рецепт";
    }
    else
    {
        ViewData["Title"] = Model.Recipe.Name;
    }
}

<h2>
    @(Model.Recipe.Id == 0 ? "Добавить новый рецепт" : "Редактировать рецепт")
</h2>

<form method="post" class="mt-4">
    <div class="form-group">
        @* ID *@
        <input type="hidden" asp-for="Recipe.Id" />
        @* /ID *@
        
        @* Название *@
        <label asp-for="Recipe.Name">Название рецепта:</label>
        <input type="text"
               asp-for="Recipe.Name"
               value="@Model.Recipe.Name"
               asp-invalid-class="is-invalid"
               class="mt-2 form-control"
               placeholder="Введите название рецепта"/>
        @* /Название *@

        @* Категория *@
        <label class="mt-3" asp-for="Recipe.CategoryId">Категория:</label>
        <select asp-for="Recipe.CategoryId" asp-items="@(new SelectList(Model.Categories, "Id", "Name"))"
                class="mt-2 form-select">
            <option value="">Выберите категорию</option>
        </select>
        @* /Категория *@
    </div>
    
    <div class="mt-3 d-flex gap-1">
        <button type="submit" class="btn btn-primary">Сохранить</button>
    </div>
</form>
