@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model RecipeCatalog.Controllers.RecipesController.RecipesViewModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Список рецептов";
}

<h2>Список рецептов</h2>

<p class="mt-1 d-flex justify-content-end">
    <a class="btn btn-primary" asp-controller="Recipes" asp-action="Edit">Добавить новый рецепт</a>
</p>

@if (Model.Recipes.Count != 0)
{
    <p class="mt-1 text-secondary">Всего рецептов: @Model.Recipes.Count</p>

    <div class="mt-2 row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var recipe in Model.Recipes)
        {
            <div class="col mt-0">
                <div class="card shadow-sm rounded-4">
                    <div class="card-body" style="padding:16px 20px">

                        <h5 class="card-title">@recipe.Name</h5>

                        <div class="d-flex align-items-center gap-2">
                            <p class="mb-0">Категория:</p>
                            <div class="bg-secondary rounded-3 text-bg-secondary"
                                 style="padding:4px 8px;font-size:13px">
                                @recipe.Category.Name
                            </div>
                        </div>

                        <div class="mt-3 row">
                            <div class="col-4 pe-1">
                                <div class="d-flex flex-column">
                                    <div style="height:60px;padding:10px;"
                                         class="flex-grow-1 bg-secondary bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center">
                                        <span class="fw-semibold text-muted">@recipe.RecipeIngredients.Count</span>
                                    </div>
                                    <p class="mb-0 text-muted text-end mt-1 text-truncate" style="font-size:13px">
                                        ингредиентов</p>
                                </div>
                            </div>
                            <div class="col-8 ps-1">
                                <div class="d-flex flex-column">
                                    <div style="height:60px;padding:10px;"
                                         class="flex-grow-1 bg-secondary bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center">
                                        <span class="fw-semibold text-muted text-center">
                                            @recipe.CreatedAt.ToString("dd MMMM yyyy 'в' HH:mm")
                                        </span>
                                    </div>
                                    <p class="mb-0 text-muted text-end mt-1 text-nowrap text-truncate"
                                       style="font-size:13px">дата добавления</p>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="card-footer d-flex flex-wrap gap-2 justify-content-end">
                        <button type="button" class="btn btn-secondary" data-bs-toggle="modal"
                                data-bs-target="#description_@recipe.Id">
                            Открыть описание
                        </button>
                        <a asp-controller="Recipes" asp-action="Edit" asp-route-id="@recipe.Id"
                           class="btn btn-primary">Изменить</a>
                        <a asp-controller="Recipes" asp-action="Delete" asp-route-id="@recipe.Id" class="btn btn-danger"
                           onclick="return confirm('Вы действительно желаете удалить рецепт?')">
                            Удалить
                        </a>
                    </div>

                    <div class="modal fade" id="description_@recipe.Id" tabindex="-1" aria-labelledby="descriptionLabel_@recipe.Id"
                         aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h1 class="modal-title fs-5" id="descriptionLabel_@recipe.Id">@recipe.Name</h1>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                                            aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    @Html.Raw(recipe.Description)
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                        Закрыть
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="mt-4 text-center">Не добавлено ни одного рецепта.</p>
}
