@page
@model RecipeCatalog.Pages.CategoryModel
@{
}

@if (Model.Category != null)
{
	<h2>
		@(Model.Category.Id == 0 ? "Добавить новую категорию" : "Редактировать категорию")
	</h2>

	<form method="post" class="mt-4">
		<div class="form-group">
			<label for="Name">Название категории:</label>
			<input type="text" id="Name" name="Name" value="@Model.Category.Name" required class="mt-2 form-control"
				placeholder="Введите название категории" />
		</div>
		<button type="submit" class="mt-3 btn btn-primary">Сохранить</button>
	</form>
}
else
{
	<h2>Категория не найдена.</h2>
}