@page
@model RecipeCatalog.Pages.Account.Login
@{
    ViewData["Title"] = "Авторизация";
}

<div class="container">
    <div class="mt-5 align-items-stretch d-flex justify-content-center">
        <div class="col-12 col-sm-10 col-lg-5 bg-secondary bg-opacity-10 rounded-5 p-4 p-sm-5">
            <h2>Авторизация</h2>
            <p class="text-secondary-emphasis mt-1 mb-0">Заполните поля, чтобы войти в аккаунт</p>
            <form style="margin-top:28px" method="post">
                <div asp-validation-summary="ModelOnly" class="ul-validation-summary mb-4 text-danger"></div>

                <div class="form-group">
                    <label asp-for="Input.Email">Email:</label>
                    <input asp-for="Input.Email" type="email" class="mt-1 form-control"
                           style="height:42px;border-radius:10px" placeholder="Введите электронную почту"/>
                    <div class="invalid-feedback d-block">
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3 form-group">
                    <label asp-for="Input.Password">Пароль:</label>
                    <input asp-for="Input.Password" type="password" class="mt-1 form-control rounded-3"
                           style="height:42px;border-radius:10px" placeholder="Введите пароль"/>
                    <div class="invalid-feedback d-block">
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end" style="margin-top:28px">
                    <button type="submit" class="btn btn-primary px-3" style="height:45px;border-radius:10px">
                        Войти
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>