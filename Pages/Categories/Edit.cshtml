@page "{id:int?}"
@model CategoryModel
@{
	bool isExists = Model.Category.Id != 0;
	if (isExists)
	{
		ViewData["Title"] = Model.Category.Name;
	}
	else
	{
		ViewData["Title"] = "Добавить категорию";
	}
}

<h2>
	@(!isExists ? "Добавить новую категорию" : "Редактировать категорию")
</h2>

<form method="post" class="mt-4">
	<div class="form-group">
		<label for="Name">Название категории:</label>
		<input type="text" id="Name" name="Name" value="@Model.Category.Name" required class="mt-2 form-control"
		       placeholder="Введите название категории"/>
	</div>
	<div class="mt-3 d-flex gap-1">
		<button type="submit" class="btn btn-primary">Сохранить</button>
		@if (isExists)
		{
			<a class="btn btn-danger" asp-page="/Categories/Delete" asp-route-id="@Model.Category.Id">
				Удалить
			</a>
		}
	</div>
</form>